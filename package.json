{
  "name": "xyphra",
  "version": "1.0.5",
  "description": "High-performance, secure request logger middleware for XyPriss G3.",
  "author": "Nehonix-Team",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "xypriss.config.jsonc",
    "xypriss.plugin.xsig"
  ],
  "keywords": [
    "xypriss",
    "xypriss-plugin",
    "logger",
    "morgan",
    "security",
    "zero-trust",
    "high-performance"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "xfpm run build && xfpm sign ./ --min-version 1.0.0 --fix"
  },
  "dependencies": {
    "xypriss": "^9.9.4",
    "nehoid": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "xfpm": {
    "permissions": [
      "XHS.HOOK.HTTP.REQUEST",
      "XHS.HOOK.HTTP.RESPONSE",
      "XHS.HOOK.LIFECYCLE.SERVER_START",
      "XHS.HOOK.LIFECYCLE.SERVER_READY",
      "XHS.PERM.SECURITY.SENSITIVE_DATA"
    ]
  }
}
